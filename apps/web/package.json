{
  "name": "@typologos/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare:static": "mkdir -p public && cp ../../node_modules/sql.js-httpvfs/dist/sqlite.worker.js ../../node_modules/sql.js-httpvfs/dist/sql-wasm.wasm public/",
    "dev:static": "npm run prepare:static && VITE_DATA_BACKEND=static vite --port 3002 --strictPort",
    "build:static": "npm run prepare:static && VITE_DATA_BACKEND=static vite build"
  },
  "dependencies": {
    "@typologos/shared": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js-httpvfs": "^0.8.12"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
